mod yields

use "std/libc" {exit}
use "std/runtime" {assert}

fn main() {
    // Check conditional yields.
    let x = if false {
        yield 1
    } else {
        yield 2
    }
    assert(x == 2, "expected 2")

    // Check closure yields.
    let y = {
        let mut sum = 0
        for let mut i = 0; i < 3; i += 1 {
            sum += i
        }
        yield sum
    }
    assert(y == 3, "expected 3")

    // Check loop yields.
    let mut value = 1
    let z = loop {
        if value % 4 != 0 {
            value += 1
            continue
        }

        yield value
    }
    assert(z == 4, "expected 4")

    // Check nested yields.
    let nested = {
        yield {
            yield if true {
                yield 5
            } else {
                yield 6
            }
        }
    }
    assert(nested == 5, "expected 5")

    // Check that we're allowed to break from a branch instead of yield.
    {
        for let mut i = 0; i < 1; i += 1 {
            let result = match false {
                true => yield true
                false => break
            }
        }

        for i = 0; i < 1; i += 1 {
            let result = if false {
                yield true
            } else {
                break
            }
        }
    }

    // Check that we're allowed to continue from a branch instead of yield.
    {
        for let mut i = 0; i < 1; i += 1 {
            let result = match false {
                true => yield true
                false => continue
            }
        }

        for i = 0; i < 1; i += 1 {
            let result = if false {
                yield true
            } else {
                continue
            }
        }
    }

    exit(0)
}
